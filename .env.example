YOUTUBE_API_KEY=your_youtube_data_api_key_here
PORT=5173
HOST=127.0.0.1

# 같은 검색 조건은 이 시간 동안 YouTube API를 다시 부르지 않고 로컬 캐시를 씁니다.
SEARCH_CACHE_TTL_HOURS=24

# YouTube API 요청 사이 최소 간격입니다. 개인용이면 1000~2000ms가 보수적입니다.
YOUTUBE_MIN_INTERVAL_MS=1500

# 기본 일일 quota 10,000 units보다 약간 낮게 잡아 과사용을 막습니다.
YOUTUBE_DAILY_QUOTA_LIMIT=9000

# Supabase를 쓰려면 아래 값을 채우세요. 비워두면 로컬 JSON 저장을 사용합니다.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_API_KEY=your_secret_api_key_here
SUPABASE_SCHEMA=public
